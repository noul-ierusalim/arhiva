	<item>
		<title>Cuvântul lui Dumnezeu la praznicul Bobotezei</title>
		<link>https://sandbox.noulierusalim.ro/cuvantul/2015/01/cuvantul-lui-dumnezeu-la-praznicul-bobotezei/</link>
		<pubDate>2015-01-19 18:00:00</pubDate>
